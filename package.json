{
  "name": "aotyfy",
  "description": "🔹 Album of the Year user & critic ratings for Spotify.",
  "version": "2.0.2",
  "author": "woidzero",
  "private": true,
  "license": "MIT",
  "scripts": {
    "watch": "spicetify watch -e",
